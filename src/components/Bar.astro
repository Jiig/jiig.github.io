<div data-search-container>
    <input type="text" class="input border-primary w-full" id="sbar" placeholder="Search or Go"/>
</div>

<script>

    const sbox : HTMLInputElement | null = document.querySelector('#sbar')
    const isDev = import.meta.env.DEV;

    function doThing() {
        if (!sbox) return; // Shouldn't happen since the only entry point is via event listener
        const query = sbox.value.trim();
        sbox.value = "";
        console.log(query)

        // Do the thing
        if (query.startsWith('?')) {
            search(query)
        } else {
            openUrl(`https://${query}`)
        }
    }

    function search(query: string) {
        const uri = `https://google.com/search?q=${encodeURI(query.slice(1))}`
        openUrl(uri)
    }

    function openUrl(uri: string) {
        if (isDev) {
            window.open(uri)
        } else {
            window.open(uri, '_self')
        }
    }

    sbox?.addEventListener('keydown', (event) => {
        if (event.key == 'Enter') {
            doThing();
        }
    });
</script>